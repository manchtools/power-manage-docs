{
	"name": "power-manage-docs",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && pagefind --site build/prerendered --output-path build/client/pagefind && bun run scripts/strip-pagefind-html.ts",
		"preview": "bun run build/index.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.16.0",
		"@sveltejs/kit": "^2.50.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^25.2.1",
		"bits-ui": "^2.16.3",
		"mode-watcher": "^1.1.0",
		"pagefind": "^1.3.0",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.48.2",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.3.5",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@markdoc/markdoc": "^0.5.1",
		"clsx": "^2.1.1",
		"github-slugger": "^2.0.0",
		"mermaid": "^11.15.0",
		"shiki": "^1.29.2",
		"svelte-markdoc-preprocess": "^3.0.0",
		"tailwind-merge": "^3.5.0"
	}
}
